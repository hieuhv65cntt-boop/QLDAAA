@model List<QuanLyAmThucNhaTrang.DAL.DANHMUC>
@{ ViewBag.Title = "Cấu hình Danh mục ẩm thực"; }

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <h3 class="fw-bold m-0"><i class="bi bi-tags text-primary me-2"></i>Quản lý Danh mục</h3>
        <button class="btn btn-primary rounded-pill fw-bold" data-bs-toggle="modal" data-bs-target="#modalThemDM">
            <i class="bi bi-plus-lg me-1"></i> Thêm danh mục
        </button>
    </div>

    @if (TempData["Success"] != null)
    {<div class="alert alert-success small">@TempData["Success"]</div>}
    @if (TempData["Error"] != null)
    {<div class="alert alert-danger small">@TempData["Error"]</div>}

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary small">
                <tr>
                    <th class="ps-4 py-3">MÃ DM</th>
                    <th>TÊN DANH MỤC</th>
                    <th>MÔ TẢ</th>
                    <th>TRẠNG THÁI</th>
                    <th class="text-end pe-4">THAO TÁC</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-muted">#@item.MaDM</td>
                        <td class="fw-bold">@item.TenDM</td>
                        <td class="text-muted small">@item.MoTa</td>
                        <td>
                            @if (item.TrangThai == "HoatDong")
                            {<span class="badge bg-success">Hoạt động</span> }
                            else
                            { <span class="badge bg-secondary">Ngừng sử dụng</span>}
                        </td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                    onclick="suaDM(@item.MaDM, '@item.TenDM', '@item.MoTa')"
                                    data-bs-toggle="modal" data-bs-target="#modalSuaDM">
                                Sửa
                            </button>
                            <form action="@Url.Action("XoaDanhMuc", "Admin")" method="POST" class="d-inline" onsubmit="return confirm('Xác nhận xóa/ngừng sử dụng danh mục này?');">
                                <input type="hidden" name="maDM" value="@item.MaDM" />
                                <button class="btn btn-sm btn-outline-danger rounded-pill px-3">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalThemDM" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form action="@Url.Action("ThemDanhMuc", "Admin")" method="POST" class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0"><h5 class="fw-bold m-0">Thêm Danh Mục Mới</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body p-4">
                <label class="small fw-bold mb-2">Tên danh mục <span class="text-danger">*</span></label>
                <input type="text" name="TenDM" class="form-control mb-3" required />
                <label class="small fw-bold mb-2">Mô tả chi tiết</label>
                <textarea name="MoTa" class="form-control" rows="3"></textarea>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Lưu danh mục</button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="modalSuaDM" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form action="@Url.Action("SuaDanhMuc", "Admin")" method="POST" class="modal-content rounded-4 border-0 shadow">
            <input type="hidden" name="MaDM" id="edit_MaDM" />
            <div class="modal-header border-0"><h5 class="fw-bold m-0">Sửa Danh Mục</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body p-4">
                <label class="small fw-bold mb-2">Tên danh mục <span class="text-danger">*</span></label>
                <input type="text" name="TenDM" id="edit_TenDM" class="form-control mb-3" required />
                <label class="small fw-bold mb-2">Mô tả</label>
                <textarea name="MoTa" id="edit_MoTa" class="form-control" rows="3"></textarea>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Cập nhật</button>
            </div>
        </form>
    </div>
</div>

<script>
    function suaDM(id, ten, mota) {
        document.getElementById('edit_MaDM').value = id;
        document.getElementById('edit_TenDM').value = ten;
        document.getElementById('edit_MoTa').value = mota;
    }
</script>