@{
    ViewBag.Title = "Bảng điều khiển - Ban Quản Trị";
    // Lấy dữ liệu thống kê từ ViewBag ra
    var tk = ViewBag.ThongKe as System.Collections.Generic.Dictionary<string, int>;
}

<div class="container mt-4 mb-5" style="min-height: 65vh;">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <div>
            <h3 class="fw-bold m-0 text-danger"><i class="bi bi-speedometer2 me-2"></i>Tổng quan Hệ thống</h3>
            <p class="text-muted small m-0 mt-1">Chào mừng Quản trị viên! Dưới đây là tình hình hoạt động của hệ thống Nha Trang Cuisine.</p>
        </div>
        <div>
            <span class="badge bg-light text-dark border p-2 shadow-sm"><i class="bi bi-calendar3 me-1"></i> Hôm nay: @DateTime.Now.ToString("dd/MM/yyyy")</span>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 bg-warning bg-opacity-10 h-100" style="border-left: 5px solid #ffc107 !important;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold text-warning m-0">ĐỊA ĐIỂM CHỜ DUYỆT</h6>
                        <i class="bi bi-shop text-warning fs-3 opacity-50"></i>
                    </div>
                    <h2 class="display-5 fw-bold  m-0">@tk["ChoDuyet"]</h2>
                    <a href="@Url.Action("KiemDuyetDiaDiem", "Admin")" class="text-decoration-none small text-warning fw-bold mt-2 d-inline-block">Xử lý ngay <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 bg-success bg-opacity-10 h-100" style="border-left: 5px solid #198754 !important;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold text-success m-0">ĐANG HOẠT ĐỘNG</h6>
                        <i class="bi bi-check-circle text-success fs-3 opacity-50"></i>
                    </div>
                    <h2 class="display-5 fw-bold  m-0">@tk["HoatDong"]</h2>
                    <span class="small text-success fw-semibold mt-2 d-inline-block">Cơ sở kinh doanh trực tuyến</span>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 bg-primary bg-opacity-10 h-100" style="border-left: 5px solid #0d6efd !important;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold text-primary m-0">TÀI KHOẢN HỆ THỐNG</h6>
                        <i class="bi bi-people text-primary fs-3 opacity-50"></i>
                    </div>
                    <h2 class="display-5 fw-bold  m-0">@tk["TaiKhoan"]</h2>
                    <span class="small text-primary fw-semibold mt-2 d-inline-block">Khách hàng & Chủ CSKD</span>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 bg-info bg-opacity-10 h-100" style="border-left: 5px solid #0dcaf0 !important;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold text-info m-0">LƯỢT ĐÁNH GIÁ</h6>
                        <i class="bi bi-star-half text-info fs-3 opacity-50"></i>
                    </div>
                    <h2 class="display-5 fw-bold  m-0">@tk["DanhGia"]</h2>
                    <span class="small text-info fw-semibold mt-2 d-inline-block">Bình luận từ cộng đồng</span>
                </div>
            </div>
        </div>
    </div>

    <h5 class="fw-bold mb-3">Truy cập nhanh chức năng</h5>
    <div class="row g-3">

        <div class="col-md-4">
            <a href="@Url.Action("KiemDuyetDiaDiem", "Admin")" class="btn btn-light border py-3 w-100 text-start rounded-3 shadow-sm">
                <i class="bi bi-shield-check text-success fs-4 me-3"></i>
                <span class="fw-bold text-dark">Kiểm duyệt địa điểm mới</span>
            </a>
        </div>

        <div class="col-md-4">
            <a href="@Url.Action("QuanLyDanhGia", "Admin")" class="btn btn-light border py-3 w-100 text-start rounded-3 shadow-sm">
                <i class="bi bi-exclamation-triangle text-danger fs-4 me-3"></i>
                <span class="fw-bold text-dark">Quản lý đánh giá</span>
            </a>
        </div>

        <div class="col-md-4">
            <a href="@Url.Action("QuanLyDanhMuc", "Admin")" class="btn btn-light border py-3 w-100 text-start rounded-3 shadow-sm">
                <i class="bi bi-tags text-primary fs-4 me-3"></i>
                <span class="fw-bold text-dark">Quản lý Danh mục ẩm thực</span>
            </a>
        </div>

        <div class="col-md-4">
            <a href="@Url.Action("BaoCaoDiaDiem", "Admin")" class="btn btn-light border py-3 w-100 text-start rounded-3 shadow-sm">
                <i class="bi bi-bar-chart-line text-info fs-4 me-3"></i>
                <span class="fw-bold text-dark">Báo cáo địa điểm</span>
            </a>
        </div>
        <div class="col-md-4">
            <a href="@Url.Action("BaoCaoDanhGia", "Admin")" class="btn btn-light border py-3 w-100 text-start rounded-3 shadow-sm">
                <i class="bi bi-bar-chart-line text-info fs-4 me-3"></i>
                <span class="fw-bold text-dark">Báo cáo đánh giá</span>
            </a>
        </div>
        <div class="col-md-4">
            <a href="@Url.Action("BaoCaoTaiKhoan", "Admin")" class="btn btn-light border py-3 w-100 text-start rounded-3 shadow-sm">
                <i class="bi bi-bar-chart-line text-info fs-4 me-3"></i>
                <span class="fw-bold text-dark">Báo cáo tài khoản</span>
            </a>
        </div>

    </div>
</div>