@model List<QuanLyAmThucNhaTrang.DAL.DIADIEM>
@{
    ViewBag.Title = "Quản trị: Kiểm duyệt địa điểm";
}

<div class="container mt-5 mb-5" style="min-height: 60vh;">
    <div class="border-bottom pb-3 mb-4">
        <h3 class="fw-bold m-0"><i class="bi bi-shield-check text-success me-2"></i>Kiểm duyệt cơ sở ẩm thực</h3>
        <p class="text-muted small m-0 mt-1">Xem xét và phê duyệt các yêu cầu đăng ký mở gian hàng mới từ Đối tác.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-3 small shadow-sm">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-3 small shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
        </div>
    }

    @if (Model != null && Model.Count > 0)
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary small">
                        <tr>
                            <th class="ps-4 py-3">STT</th>
                            <th class="py-3">TÊN QUÁN ĐĂNG KÝ</th>
                            <th class="py-3">CHỦ CƠ SỞ</th>
                            <th class="py-3">DANH MỤC</th>
                            <th class="py-3">NGÀY ĐĂNG KÝ</th>
                            <th class="text-end pe-4 py-3">THAO TÁC</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int stt = 1; }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted fw-bold align-middle">@stt</td>
                                <td class="align-middle">

                                    <div class="mb-1 d-flex align-items-center gap-2">
                                        @if (item.TrangThai.Trim() == "ChoDuyetSua")
                                        {
                                            <span class="badge bg-info text-dark border border-info border-opacity-25 rounded-pill px-2 py-1 shadow-sm" style="font-size: 0.7rem;">
                                                <i class="bi bi-pencil-square me-1"></i> Xin sửa thông tin
                                            </span>
                                            <span class="text-muted fst-italic" style="font-size: 0.75rem;">(Bản nháp từ ID gốc: #@item.MaDD_Goc)</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary bg-gradient text-white border rounded-pill px-2 py-1 shadow-sm" style="font-size: 0.7rem;">
                                                <i class="bi bi-shop me-1"></i> Đăng ký mới
                                            </span>
                                        }
                                    </div>

                                    <h6 class="fw-bold text-body m-0 fs-5">@item.TenDD</h6>
                                    <small class="text-muted d-block mb-2"><i class="bi bi-geo-alt me-1"></i>@item.DiaChiChiTiet</small>

                                    @if (item.HINHANH != null && item.HINHANH.Count > 0)
                                    {
                                        <div class="d-flex gap-2 mt-2">
                                            @foreach (var anh in item.HINHANH)
                                            {
                                                <a href="@anh.DuongDan" target="_blank" title="Click để phóng to hình ảnh">
                                                    <img src="@anh.DuongDan" class="rounded border shadow-sm"
                                                         style="width: 60px; height: 45px; object-fit: cover; cursor: pointer; transition: transform 0.2s;"
                                                         onmouseover="this.style.transform='scale(1.1)'"
                                                         onmouseout="this.style.transform='scale(1)'" />
                                                </a>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <small class="text-danger d-block mt-1"><i class="bi bi-image-alt"></i> Không có ảnh xác minh!</small>
                                    }
                                </td>

                                <td class="align-middle">
                                    <span class="d-block fw-semibold text-primary">@item.TAIKHOAN.HoTen</span>
                                    <small class="text-muted">SĐT: @item.SDT</small>
                                </td>
                                <td class="align-middle"><span class="badge bg-light text-dark border">@item.DANHMUC.TenDM</span></td>

                                <td class="text-muted small align-middle">
                                    @(item.NgayDangKy.Year > 2000 ? item.NgayDangKy.ToString("dd/MM/yyyy HH:mm") : "Vừa cập nhật")
                                </td>

                                <td class="text-end pe-4 align-middle">
                                    <div class="d-inline-flex flex-wrap gap-2 justify-content-end">

                                        <a href="@Url.Action("ChiTiet", "DiaDiem", new { id = item.MaDD })" class="btn btn-outline-secondary btn-sm rounded-pill" target="_blank" title="Xem chi tiết nội dung">
                                            <i class="bi bi-eye"></i> @(item.TrangThai.Trim() == "ChoDuyetSua" ? "Xem bản nháp" : "Xem trước")
                                        </a>

                                        <form action="@Url.Action("PheDuyet", "Admin")" method="POST" onsubmit="return confirm('Bạn xác nhận PHÊ DUYỆT yêu cầu này?');" class="m-0">
                                            <input type="hidden" name="maDD" value="@item.MaDD" />
                                            <button type="submit" class="btn btn-success btn-sm rounded-pill fw-bold shadow-sm">
                                                <i class="bi bi-check-lg me-1"></i> Duyệt
                                            </button>
                                        </form>

                                        <button type="button" class="btn btn-danger btn-sm rounded-pill fw-bold shadow-sm"
                                                onclick="moModalTuChoi(@item.MaDD, '@item.TenDD', '@(item.TrangThai.Trim() == "ChoDuyetSua" ? "Bản nháp cập nhật" : "Đăng ký mới")')"
                                                data-bs-toggle="modal" data-bs-target="#modalTuChoi">
                                            <i class="bi bi-x-lg me-1"></i> Từ chối
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            stt++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 border rounded-4 bg-light bg-opacity-10">
            <i class="bi bi-clipboard2-check text-success display-3"></i>
            <h5 class="text-muted mt-3 fw-bold">Tất cả địa điểm đã được kiểm duyệt</h5>
            <p class="text-secondary small">Hiện tại không có yêu cầu đăng ký hoặc cập nhật quán ăn mới nào từ Đối tác.</p>
        </div>
    }
</div>
<div class="modal fade" id="modalTuChoi" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form action="@Url.Action("TuChoi", "Admin")" method="POST" class="modal-content rounded-4 border-0 shadow">
            <input type="hidden" name="maDD" id="tuchoi_MaDD" />
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="fw-bold m-0 text-danger"><i class="bi bi-exclamation-octagon-fill me-2"></i>Từ chối phê duyệt</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <p class="mb-2">Bạn đang từ chối cơ sở: <strong id="tuchoi_TenQuan" class="text-primary"></strong></p>
                <label class="small fw-bold mb-2 text-muted">Vui lòng nhập lý do từ chối để thông báo cho đối tác <span class="text-danger">*</span></label>
                <textarea name="lyDo" class="form-control bg-transparent text-body" rows="3" placeholder="VD: Hình ảnh cung cấp bị mờ, địa chỉ không rõ ràng..." required></textarea>
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Hủy bỏ</button>
                <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">Xác nhận Từ chối</button>
            </div>
        </form>
    </div>
</div>

<script>
    // Script để truyền dữ liệu mã quán, tên quán và Loại Đơn vào Modal khi bấm nút Từ chối
    function moModalTuChoi(maDD, tenDD, loaiDon) {
        document.getElementById('tuchoi_MaDD').value = maDD;

        // Hiện thông báo chi tiết: "Từ chối Bún cá Hà Dứa (Bản nháp cập nhật)"
        document.getElementById('tuchoi_TenQuan').innerText = tenDD + ' [' + loaiDon + ']';
    }
</script>