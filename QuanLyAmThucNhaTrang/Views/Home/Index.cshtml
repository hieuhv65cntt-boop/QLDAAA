@model List<QuanLyAmThucNhaTrang.DAL.DIADIEM>
@{
    ViewBag.Title = "Khám Phá Ẩm Thực Nha Trang";
}

<div class="p-5 mb-4 bg-light rounded-4 position-relative overflow-hidden shadow-sm"
     style="background: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.6)), url('https://images.unsplash.com/photo-1540189549336-e6e99c3679fe?auto=format&fit=crop&q=80&w=1200') center/cover; border-radius: 24px !important;">
    <div class="container-fluid py-4 text-white">
        <span class="badge bg-warning text-dark fw-bold mb-2 px-3 py-2 rounded-pill text-uppercase tracking-wider" style="font-size: 0.75rem;">Tinh hoa xứ biển</span>
        <h1 class="display-5 fw-bold" style="font-family: 'Playfair Display', serif;">Hôm nay bạn muốn ăn gì?</h1>
        <p class="col-md-8 fs-6 opacity-75">Hàng trăm địa điểm bún cá, nem nướng, hải sản tươi sống chất lượng nhất tại Nha Trang đã được kiểm duyệt và đánh giá minh bạch bởi cộng đồng du khách.</p>
        <a href="@Url.Action("TimKiem", "DiaDiem")" class="btn btn-primary rounded-pill px-4 py-2 fw-semibold shadow-sm"><i class="bi bi-compass me-2"></i>Khám phá ngay</a>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-4 mt-5">
    <div>
        <h3 class="fw-bold m-0" style="font-family: 'Playfair Display', serif;">Địa điểm nổi bật nhất</h3>
        <p class="text-muted small m-0">Những tọa độ ẩm thực không thể bỏ qua khi tới Nha Trang</p>
    </div>
    <a href="@Url.Action("TimKiem", "DiaDiem")" class="text-decoration-none fw-bold small">Xem tất cả <i class="bi bi-arrow-right"></i></a>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mx-0">
    @if (Model != null && Model.Count > 0)
    {
        foreach (var item in Model)
        {
            // Logic lấy ảnh đại diện mặt tiền (nếu quán không có ảnh thì lấy ảnh mặc định)
            var anhMatTien = item.HINHANH.FirstOrDefault(h => h.LoaiHinhAnh == "MatTien")?.DuongDan
                             ?? "https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&q=80&w=600";

            <div class="col" data-aos="fade-up">
                <div class="card h-100 border-0 shadow-sm overflow-hidden border border-translucent @(item.TrangThai == "TamNgung" ? "card-tamngung" : "")" style="border-radius: 20px; transition: all 0.3s ease;">
                    <div class="position-relative overflow-hidden" style="height: 200px;">

                        @if (item.TrangThai == "TamNgung")
                        {
                            <div class="ribbon-tamngung border border-warning text-nowrap shadow-lg">
                                <i class="bi bi-lock-fill me-2 text-warning"></i>TẠM NGHỈ BÁN
                            </div>
                        }

                        <img src="@Url.Content("~" + anhMatTien)" class="w-100 h-100 object-fit-cover" alt="@item.TenDD" style="transition: transform 0.5s ease;" onmouseover="this.style.transform='scale(1.08)'" onmouseout="this.style.transform='scale(1)'">
                        <span class="position-absolute top-0 start-0 m-3 badge bg-white text-dark fw-bold border shadow-sm px-2.5 py-1.5" style="border-radius: 8px; font-size: 0.8rem;">
                            <i class="bi bi-tag-fill text-primary me-1"></i> @item.DANHMUC.TenDM
                        </span>
                    </div>

                    <div class="card-body d-flex flex-column p-4">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold text-truncate mb-0" style="max-width: 80%;" title="@item.TenDD">@item.TenDD</h5>
                            <div class="d-inline-flex align-items-center gap-1 bg-warning bg-opacity-10 text-warning px-2 py-0.5 rounded-3 border border-warning border-opacity-25 small fw-bold">
                                <i class="bi bi-star-fill"></i> @item.DiemDanhGiaTB
                            </div>
                        </div>

                        <p class="card-text text-secondary small mb-3 text-truncate-2" style="height: 40px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4;">
                            <i class="bi bi-geo-alt-fill text-danger me-1"></i> @item.DiaChiChiTiet
                        </p>

                        <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top border-light-subtle text-muted small">
                            <span><i class="bi bi-clock me-1"></i> @(item.GioMoCua?.ToString(@"hh\:mm") ?? "06:00") - @(item.GioDongCua?.ToString(@"hh\:mm") ?? "22:00")</span>
                            <span><i class="bi bi-chat-left-text me-1"></i> @item.SoLuotDanhGia đánh giá</span>
                        </div>
                    </div>

                    <div class="px-4 pb-4">
                        <a href="@Url.Action("ChiTiet", "DiaDiem", new { id = item.MaDD })" class="btn btn-outline-primary btn-sm rounded-pill w-100 py-2 fw-semibold d-inline-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-eye"></i> Xem thông tin chi tiết
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <i class="bi bi-inbox text-muted display-1"></i>
            <p class="text-muted mt-3">Chưa có địa điểm ẩm thực nào được kích hoạt hiển thị.</p>
        </div>
    }
</div>

<style>
    /* Class làm mờ và mất màu */
    .card-tamngung {
        opacity: 0.65;
        filter: grayscale(80%);
        pointer-events: none; /* Tùy chọn: Chặn click nếu không muốn khách vào xem chi tiết */
        transition: all 0.3s ease;
    }

    /* Nhãn đè lên ảnh */
    .ribbon-tamngung {
        position: absolute;
        top: 40%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: rgba(0,0,0,0.8);
        color: white;
        padding: 10px 20px;
        font-weight: bold;
        border-radius: 8px;
        z-index: 10;
        letter-spacing: 1px;
    }
</style>
