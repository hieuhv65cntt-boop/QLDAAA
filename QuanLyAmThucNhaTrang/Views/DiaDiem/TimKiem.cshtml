@model List<QuanLyAmThucNhaTrang.DAL.DIADIEM>
@{
    ViewBag.Title = "Tìm Kiếm Địa Điểm Ẩm Thực";
    var danhMucList = ViewBag.DanhMucList as List<QuanLyAmThucNhaTrang.DAL.DANHMUC>;
    var khuVucList = ViewBag.KhuVucList as List<QuanLyAmThucNhaTrang.DAL.KHUVUC>;
}

<div class="container mt-4">
    <div class="row g-4">

        <div class="col-lg-3">
            <div class="card border border-translucent shadow-sm p-4 rounded-4 position-sticky" style="top: 90px;">
                <h5 class="fw-bold mb-4 d-inline-flex align-items-center gap-2">
                    <i class="bi bi-sliders text-primary"></i> Bộ lọc tìm kiếm
                </h5>

                <form action="@Url.Action("TimKiem", "DiaDiem")" method="GET" id="filterForm">

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-secondary">Từ khóa</label>
                        <div class="input-group">
                            <span class="input-group-text border-0"><i class="bi bi-search text-muted"></i></span>
                            <input type="text" name="tuKhoa" class="form-control border-0 small"
                                   placeholder="Tên quán, món ăn..." value="@ViewBag.TuKhoaHienTai" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-secondary">Khu vực địa lý</label>
                        <select name="maKV" class="form-select border-0 small" onchange="document.getElementById('filterForm').submit();">
                            <option value="">-- Tất cả khu vực --</option>
                            @if (khuVucList != null)
                            {
                                foreach (var kv in khuVucList)
                                {
                                    <option value="@kv.MaKV" @(ViewBag.MaKVHienTai == kv.MaKV ? "selected" : "")>@kv.TenKV</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-secondary d-block mb-2">Danh mục ẩm thực</label>

                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="maDM" id="dm_all" value=""
                                   @(ViewBag.MaDMHienTai == null ? "checked" : "") onchange="document.getElementById('filterForm').submit();">
                            <label class="form-check-label small" for="dm_all">Tất cả danh mục</label>
                        </div>

                        @if (danhMucList != null)
                        {
                            foreach (var dm in danhMucList)
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="radio" name="maDM" id="dm_@dm.MaDM" value="@dm.MaDM"
                                           @(ViewBag.MaDMHienTai == dm.MaDM ? "checked" : "") onchange="document.getElementById('filterForm').submit();">
                                    <label class="form-check-label small" for="dm_@dm.MaDM">@dm.TenDM</label>
                                </div>
                            }
                        }
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill fw-bold py-2 small">
                            <i class="bi bi-funnel-fill me-1"></i> Áp dụng bộ lọc
                        </button>
                        <a href="@Url.Action("TimKiem", "DiaDiem")" class="btn btn-light rounded-pill border-0 text-secondary fw-semibold py-2 small text-center">
                            Xóa bộ lọc
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-9">
            <div class=" p-3 rounded-4 border border-light-subtle d-flex justify-content-between align-items-center mb-4">
                <span class="text-secondary small fw-semibold d-inline-flex align-items-center gap-2">
                    <i class="bi bi-info-circle text-primary"></i> Tìm thấy <strong class="text-primary">@Model.Count</strong> địa điểm phù hợp
                </span>
                <span class="text-muted small">Sắp xếp: <strong>Đánh giá cao nhất</strong></span>
            </div>

            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        var anhMatTien = item.HINHANH.FirstOrDefault(h => h.LoaiHinhAnh == "MatTien")?.DuongDan;
                        var urlAnh = string.IsNullOrEmpty(anhMatTien)
                            ? "https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&q=80&w=600"
                            : Url.Content("~" + anhMatTien);

                        <div class="col">
                            <div class="card h-100 border border-translucent shadow-sm overflow-hidden @(item.TrangThai == "TamNgung" ? "card-tamngung" : "")" style="border-radius: 18px; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'">

                                <div class="position-relative" style="height: 160px;">
                                    @if (item.TrangThai == "TamNgung")
                                    {
                                        <div class="ribbon-tamngung border border-warning text-nowrap shadow-lg">
                                            <i class="bi bi-lock-fill me-1 text-warning"></i>TẠM NGHỈ
                                        </div>
                                    }

                                    <img src="@urlAnh" class="w-100 h-100 object-fit-cover" alt="@item.TenDD" />
                                    <span class="position-absolute top-0 start-0 m-2 badge bg-white text-dark border shadow-sm px-2 py-1 small" style="border-radius: 6px;">
                                        @item.DANHMUC.TenDM
                                    </span>
                                </div>

                                <div class="card-body d-flex flex-column p-3">
                                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                        <h6 class="fw-bold text-truncate mb-0" style="max-width: 80%;" title="@item.TenDD">@item.TenDD</h6>
                                        <span class="badge bg-warning bg-opacity-10 text-warning px-1.5 py-0.5 rounded border border-warning border-opacity-25 small fw-bold">
                                            <i class="bi bi-star-fill"></i> @item.DiemDanhGiaTB
                                        </span>
                                    </div>
                                    <p class="text-secondary mb-3 text-truncate-2 small" style="height: 36px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.3;">
                                        <i class="bi bi-geo-alt-fill text-danger me-1"></i> @item.DiaChiChiTiet
                                    </p>
                                    <div class="mt-auto">
                                        <a href="@Url.Action("ChiTiet", "DiaDiem", new { id = item.MaDD })" class="btn btn-outline-primary btn-sm rounded-pill w-100 py-2 fw-semibold small d-inline-flex align-items-center justify-content-center gap-1">
                                            <i class="bi bi-eye"></i> Chi tiết
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <i class="bi bi-search-heart text-muted display-3"></i>
                        <h5 class="text-muted mt-3 fw-bold">Không tìm thấy kết quả nào</h5>
                        <p class="text-secondary small">Thử thay đổi từ khóa hoặc điều kiện lọc của bạn xem sao nhé.</p>
                    </div>
                }
            </div>
        </div>

    </div>
</div>

<style>
    /* Class làm mờ và mất màu */
    .card-tamngung {
        opacity: 0.65;
        filter: grayscale(80%);
        pointer-events: none; /* Chặn click vào xem chi tiết */
        transition: all 0.3s ease;
    }

    /* Nhãn đè lên ảnh (đã được tinh chỉnh kích thước cho phù hợp với card nhỏ) */
    .ribbon-tamngung {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: rgba(0,0,0,0.8);
        color: white;
        padding: 6px 14px;
        font-size: 0.85rem;
        font-weight: bold;
        border-radius: 6px;
        z-index: 10;
        letter-spacing: 0.5px;
    }
</style>