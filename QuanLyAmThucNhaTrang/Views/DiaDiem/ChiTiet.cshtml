@model QuanLyAmThucNhaTrang.DAL.DIADIEM
<script src="https://cdnjs.cloudflare.com/ajax/libs/fslightbox/3.0.9/index.min.js"></script>
@{
    ViewBag.Title = Model.TenDD;
    var danhSachKM = ViewBag.KhuyenMaiList as List<QuanLyAmThucNhaTrang.DAL.KHUYENMAI>;
    // Xử lý ảnh mặt tiền (Cover Image)
    var anhMatTien = Model.HINHANH.FirstOrDefault(h => h.LoaiHinhAnh == "MatTien")?.DuongDan;
    var urlAnhCover = string.IsNullOrEmpty(anhMatTien)
        ? "https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&q=80&w=1200"
        : Url.Content("~" + anhMatTien);

}

<div class="position-relative mt-4 rounded-4 overflow-hidden shadow-sm" style="height: 400px;">
    <div class="position-absolute top-0 start-0 w-100 h-100"
         style="background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.6) 100%), url('@urlAnhCover') center/cover; z-index: 1;">
    </div>

    @if (Model.TrangThai == "TamNgung")
    {
        <div class="container mt-4">
            <div class="alert alert-warning bg-warning bg-opacity-10 border-warning border-start border-4 rounded-3 d-flex align-items-center p-4 shadow-sm">
                <i class="bi bi-exclamation-triangle-fill fs-1 text-warning me-4"></i>
                <div>
                    <h4 class="fw-bold text-dark mb-1">Cơ sở này đang tạm ngưng hoạt động!</h4>
                    <p class="mb-0 text-secondary">Chủ cơ sở đang tạm thời đóng cửa quán (Có thể do nghỉ lễ, sửa chữa hoặc bảo trì). Vui lòng lưu lại và quay lại trải nghiệm vào lần sau bạn nhé.</p>
                </div>
            </div>
        </div>
    }

    <div class="position-absolute top-0 start-0 p-4" style="z-index: 2;">
        <a href="@Url.Action("Index", "Home")" class="btn btn-light btn-sm rounded-pill fw-bold bg-opacity-75 backdrop-blur">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="position-absolute bottom-0 start-0 p-4 w-100 text-white" style="z-index: 2;">
        <div class="container">
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge bg-primary px-3 py-2 rounded-pill shadow-sm"><i class="bi bi-tag-fill me-1"></i> @Model.DANHMUC.TenDM</span>
                <span class="badge bg-success bg-opacity-75 px-3 py-2 rounded-pill"><i class="bi bi-check-circle me-1"></i> Đã kiểm duyệt</span>
            </div>
            <h1 class="display-4 text-white fw-bold mb-1" style="font-family: 'Playfair Display'">@Model.TenDD</h1>
            <p class="fs-5 opacity-75 mb-0"><i class="bi bi-geo-alt-fill text-danger me-2"></i>@Model.DiaChiChiTiet, @Model.KHUVUC.TenKV</p>
        </div>
    </div>
</div>

<div class="container mt-5 mb-5">
    <div class="row g-5">

        <div class="col-lg-8">

            @if (danhSachKM != null && danhSachKM.Count > 0)
            {
                <div class="mb-5">
                    <h4 class="fw-bold border-bottom pb-2 mb-4"><i class="bi bi-gift-fill text-danger me-2"></i>Ưu đãi đang diễn ra</h4>
                    <div class="row g-3">
                        @foreach (var km in danhSachKM)
                        {
                            <div class="col-12">
                                <div class="card border-0 bg-danger bg-opacity-10 rounded-4 position-relative overflow-hidden shadow-sm"
                                     style="border-left: 6px dashed #dc3545 !important;">

                                    <div class="card-body p-3 p-md-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                                        <div class="flex-grow-1 ps-2">
                                            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                                <h5 class="fw-bold text-danger m-0">@km.TenKM</h5>
                                                <span class="badge bg-danger rounded-pill shadow-sm">
                                                    <i class="bi bi-clock-history me-1"></i> HSD: @km.NgayKetThuc.ToString("dd/MM/yyyy")
                                                </span>
                                            </div>
                                            <p class="small mb-0" style="line-height: 1.5; text-align: justify;">@km.NoiDungUuDai</p>
                                        </div>

                                        <div class="flex-shrink-0 text-md-end mt-2 mt-md-0">
                                            <button class="btn btn-danger rounded-pill fw-bold px-4 py-2 w-100 shadow-sm"
                                                    onclick="alert('Hãy đưa màn hình này cho nhân viên khi thanh toán để được áp dụng ưu đãi nhé!')">
                                                <i class="bi bi-ticket-perforated-fill me-1"></i> Sử dụng ưu đãi
                                            </button>
                                        </div>
                                    </div>
                                    <div class="position-absolute top-50 start-0 translate-middle bg-white rounded-circle" style="width: 24px; height: 24px; box-shadow: inset -3px 0 5px rgba(0,0,0,0.05);"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }


            <div class="mt-4">
                <ul class="nav nav-tabs border-bottom-0 gap-3 mb-3" id="galleryTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active fw-bold fs-5 px-0 pb-2 text-green bg-transparent border-0 border-bottom border-3 border-primary"
                                id="khonggian-tab" data-bs-toggle="tab" data-bs-target="#khonggian" type="button" role="tab" style="border-radius: 0;">
                            Không gian
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold fs-5 px-0 pb-2 text-muted bg-transparent border-0 border-bottom border-3 border-transparent"
                                id="thucdon-tab" data-bs-toggle="tab" data-bs-target="#thucdon" type="button" role="tab" style="border-radius: 0;">
                            Thực đơn
                        </button>
                    </li>
                </ul>

                <div class="tab-content" id="galleryTabsContent">

                    <div class="tab-pane fade show active" id="khonggian" role="tabpanel">
                        @{
                            var anhKhongGian = Model.HINHANH.Where(h => h.LoaiHinhAnh == "MatTien" || h.LoaiHinhAnh == "KhongGian").ToList();
                            int maxHienThi = 6;
                        }
                        @if (anhKhongGian.Any())
                        {
                            <div class="row g-2">
                                @for (int i = 0; i < anhKhongGian.Count; i++)
                                {
                                    <div class="col-4 col-md-3 col-lg-2">
                                        <a href="@Url.Content("~" + anhKhongGian[i].DuongDan)" data-fancybox="khonggian" class="position-relative d-block overflow-hidden rounded-3 @(i >= maxHienThi ? "d-none" : "")" style="height: 110px;">
                                            <img src="@Url.Content("~" + anhKhongGian[i].DuongDan)" class="w-100 h-100 object-fit-cover" />
                                            @if (i == maxHienThi - 1 && anhKhongGian.Count > maxHienThi)
                                            {
                                                <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-50 text-white fw-bold">
                                                    +@(anhKhongGian.Count - maxHienThi)
                                                </div>
                                            }
                                        </a>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small fst-italic">Chưa có ảnh không gian.</p>
                        }
                    </div>

                    <div class="tab-pane fade" id="thucdon" role="tabpanel">
                        @{
                            var anhThucDon = Model.HINHANH.Where(h => h.LoaiHinhAnh == "ThucDon").ToList();
                        }
                        @if (anhThucDon.Any())
                        {
                            <div class="row g-2">
                                @for (int i = 0; i < anhThucDon.Count; i++)
                                {
                                    <div class="col-4 col-md-3 col-lg-2">
                                        <a href="@Url.Content("~" + anhThucDon[i].DuongDan)" data-fancybox="thucdon" class="position-relative d-block overflow-hidden rounded-3 @(i >= maxHienThi ? "d-none" : "")" style="height: 110px;">
                                            <img src="@Url.Content("~" + anhThucDon[i].DuongDan)" class="w-100 h-100 object-fit-cover" />
                                            @if (i == maxHienThi - 1 && anhThucDon.Count > maxHienThi)
                                            {
                                                <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-50 text-white fw-bold">
                                                    +@(anhThucDon.Count - maxHienThi)
                                                </div>
                                            }
                                        </a>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small fst-italic">Chưa có ảnh thực đơn.</p>
                        }
                    </div>

                </div>
            </div>

            <script>
                // Script nhỏ để đổi màu viền Tab khi click
                document.querySelectorAll('#galleryTabs .nav-link').forEach(tab => {
                    tab.addEventListener('click', function () {
                        document.querySelectorAll('#galleryTabs .nav-link').forEach(t => {
                            t.classList.remove('text-green', 'border-primary');
                            t.classList.add('text-muted', 'border-transparent');
                        });
                        this.classList.remove('text-muted', 'border-transparent');
                        this.classList.add('text-green', 'border-primary');
                    });
                });
            </script>

            <style>
                /* Hiệu ứng Zoom khi hover vào ảnh */
                .gallery-item img {
                    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
                }

                .gallery-item:hover img {
                    transform: scale(1.1);
                }

                .backdrop-blur-sm {
                    backdrop-filter: blur(4px);
                    -webkit-backdrop-filter: blur(4px);
                }
                /* Làm cho ảnh tối đi một chút khi hover để nổi bật icon */
                .gallery-item:hover {
                    filter: brightness(1.1);
                }
            </style>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-4">
                    <h4 class="fw-bold m-0">Đánh giá từ cộng đồng (@Model.DANHGIA.Count)</h4>
                    <button type="button" class="btn btn-outline-primary btn-sm rounded-pill fw-semibold" data-bs-toggle="modal" data-bs-target="#reviewModal">
                        <i class="bi bi-pencil-square me-1"></i> Viết đánh giá
                    </button>
                </div>

                @if (Model.DANHGIA.Any())
                {
                    foreach (var dg in Model.DANHGIA.OrderByDescending(d => d.NgayDanhGia))
                    {
                        <div class="d-flex gap-3 mb-4 p-3 rounded-4 border-0">
                            <div class="bg-secondary bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center text-secondary fw-bold" style="width: 48px; height: 48px; flex-shrink: 0;">
                                @dg.TAIKHOAN.HoTen.Substring(0, 1).ToUpper()
                            </div>
                            <div>
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <h6 class="fw-bold m-0">@dg.TAIKHOAN.HoTen</h6>
                                    <small class="text-muted">@dg.NgayDanhGia.ToString("dd/MM/yyyy")</small>
                                </div>
                                <div class="text-warning small mb-2">
                                    @for (int i = 0; i < dg.SoSao; i++)
                                    {<i class="bi bi-star-fill"></i>}
                                    @for (int i = dg.SoSao; i < 5; i++)
                                    {<i class="bi bi-star text-muted opacity-25"></i>}
                                </div>
                                <p class="text-secondary small m-0" style="line-height: 1.6;">@dg.NoiDung</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-4 bg-light rounded-4 border-dashed">
                        <i class="bi bi-chat-square-text text-muted fs-2"></i>
                        <p class="text-muted mt-2 mb-0">Chưa có đánh giá nào. Hãy là người đầu tiên trải nghiệm!</p>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-4">
            <div class="sticky-top" style="top: 100px; z-index: 1;">

                <div class="card border border-translucent shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div class="bg-warning bg-opacity-10 text-warning px-3 py-2 rounded-3 text-center border border-warning border-opacity-25">
                                <h3 class="fw-bold m-0">@Model.DiemDanhGiaTB</h3>
                                <div class="small" style="font-size: 0.65rem;">
                                    <i class="bi bi-star-fill"></i> HẢO HẠNG
                                </div>
                            </div>
                            <div>
                                <p class="fw-bold m-0 text-success"><i class="bi bi-door-open-fill me-1"></i> @(Model.TrangThai == "DangHoatDong" ? "Đang mở cửa" : "Đóng cửa")</p>
                                <p class="text-muted small m-0">@(Model.GioMoCua?.ToString(@"hh\:mm") ?? "06:00") - @(Model.GioDongCua?.ToString(@"hh\:mm") ?? "22:00")</p>
                            </div>
                        </div>

                        <ul class="list-unstyled mb-4">
                            <li class="d-flex align-items-start gap-3 mb-3">
                                <i class="bi bi-telephone text-primary fs-5 mt-1"></i>
                                <div>
                                    <strong class="d-block small">Số điện thoại</strong>
                                    <span class="text-secondary">@(string.IsNullOrEmpty(Model.SDT) ? "Chưa cập nhật" : Model.SDT)</span>
                                </div>
                            </li>
                            <li class="d-flex align-items-start gap-3 mb-3">
                                <i class="bi bi-map text-primary fs-5 mt-1"></i>
                                <div>
                                    <strong class="d-block small">Chỉ đường</strong>
                                    <span class="text-secondary small">@Model.DiaChiChiTiet</span>
                                </div>
                            </li>
                        </ul>

                        <button id="btnYeuThich" onclick="thucHienYeuThich(@Model.MaDD)"
                                class="btn w-100 rounded-pill fw-bold py-2 shadow-sm d-flex justify-content-center align-items-center gap-2 @(ViewBag.DaLuu == true ? "btn-danger" : "btn-outline-danger")">
                            <i id="iconYeuThich" class="bi @(ViewBag.DaLuu == true ? "bi-bookmark-heart-fill" : "bi-bookmark-heart")"></i>
                            <span id="textYeuThich">@(ViewBag.DaLuu == true ? "Đã lưu vào Yêu thích" : "Lưu vào Yêu thích")</span>
                        </button>
                    </div>
                </div>

                <div class="card border border-translucent shadow-sm rounded-4 overflow-hidden">
                    <div class="card-header border-bottom-0 pt-3 pb-0 px-4">
                        <h6 class="fw-bold"><i class="bi bi-pin-map-fill text-danger me-1"></i> Vị trí trên bản đồ</h6>
                    </div>
                    <div class="card-body p-3">
                        <div id="chiTietMap" class="rounded-3 overflow-hidden shadow-sm border border-light-subtle" style="height: 250px; width: 100%; z-index: 1;">
                        </div>

                        <div class="mt-3 text-center d-flex justify-content-center gap-2">
                            <button onclick="map.setView([toaDoLat, toaDoLng], 17);" class="btn btn-sm btn-outline-secondary rounded-pill fw-bold" style="font-size: 0.8rem;">
                                <i class="bi bi-bullseye me-1"></i> Định vị lại
                            </button>
                            <a href="@Url.Action("BanDo", "DiaDiem")" target="_blank" class="btn btn-sm btn-primary rounded-pill fw-bold shadow-sm" style="font-size: 0.8rem;">
                                <i class="bi bi-cursor me-1"></i> Dẫn đường đi
                            </a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    .backdrop-blur {
        backdrop-filter: blur(8px);
    }
</style>

<div class="modal fade" id="reviewModal" tabindex="-1" aria-labelledby="reviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-primary text-white border-0 py-3">
                <h5 class="modal-title fw-bold" id="reviewModalLabel"><i class="bi bi-star-fill me-2"></i>Chia sẻ trải nghiệm</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            @if (Session["MaTK"] == null)
            {
                <div class="modal-body text-center py-5">
                    <i class="bi bi-shield-lock text-muted display-4 mb-3"></i>
                    <h5 class="fw-bold">Yêu cầu đăng nhập</h5>
                    <p class="text-secondary small">Bạn cần là thành viên để có thể gửi đánh giá cho @Model.TenDD.</p>
                    <a href="@Url.Action("DangNhap", "TaiKhoan")" class="btn btn-primary rounded-pill px-4 mt-2">Đăng nhập ngay</a>
                </div>
            }
            else
            {
                <form action="@Url.Action("ThemDanhGia", "DiaDiem")" method="POST">
                    <div class="modal-body p-4">
                        <input type="hidden" name="MaDD" value="@Model.MaDD" />

                        <div class="text-center mb-4">
                            <label class="fw-bold text-secondary mb-2 d-block">Bạn đánh giá địa điểm này mấy sao?</label>

                            <div class="star-rating-group">
                                <input type="radio" id="star5" name="SoSao" value="5" required />
                                <label for="star5" title="5 sao - Tuyệt vời!"><i class="bi bi-star-fill"></i></label>

                                <input type="radio" id="star4" name="SoSao" value="4" />
                                <label for="star4" title="4 sao - Rất tốt"><i class="bi bi-star-fill"></i></label>

                                <input type="radio" id="star3" name="SoSao" value="3" />
                                <label for="star3" title="3 sao - Bình thường"><i class="bi bi-star-fill"></i></label>

                                <input type="radio" id="star2" name="SoSao" value="2" />
                                <label for="star2" title="2 sao - Tệ"><i class="bi bi-star-fill"></i></label>

                                <input type="radio" id="star1" name="SoSao" value="1" />
                                <label for="star1" title="1 sao - Quá tệ"><i class="bi bi-star-fill"></i></label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold text-secondary small mb-2">Chi tiết trải nghiệm của bạn</label>
                            <textarea name="NoiDung" class="form-control bg-light border-0 rounded-3" rows="4" placeholder="Món ăn có ngon không? Phục vụ thế nào? Không gian ra sao?..." required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer bg-light border-0 py-3">
                        <button type="button" class="btn btn-outline-secondary rounded-pill fw-semibold" data-bs-dismiss="modal">Hủy bỏ</button>
                        <button type="submit" class="btn btn-primary rounded-pill fw-bold shadow-sm px-4">Gửi đánh giá</button>
                    </div>
                </form>
            }
        </div>
    </div>
</div>

<style>
    /* CSS TRICK: Đảo ngược chiều chọn sao để làm hiệu ứng sáng từ trái qua phải */
    .star-rating-group {
        display: inline-flex;
        flex-direction: row-reverse;
        justify-content: center;
    }

        .star-rating-group input {
            display: none;
        }

        .star-rating-group label {
            color: #e4e5e9; /* Màu sao xám mặc định */
            font-size: 2.2rem;
            padding: 0 0.2rem;
            cursor: pointer;
            transition: color 0.2s ease-in-out;
        }
            /* Hover vào 1 sao -> Tất cả sao bên trái (đã bị đảo ngược) sáng lên */
            .star-rating-group label:hover,
            .star-rating-group label:hover ~ label {
                color: #ffc107;
            }

        /* Khi click chọn 1 sao -> Giữ màu vàng cho nó và các sao bên trái */
        .star-rating-group input:checked ~ label {
            color: #ffc107;
        }
</style>

<script>
    function thucHienYeuThich(maDD) {
        // Gửi yêu cầu POST ngầm lên Controller bằng Fetch API (AJAX)
        fetch('@Url.Action("ToggleYeuThich", "KhachHang")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'maDD=' + maDD
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                var btn = document.getElementById('btnYeuThich');
                var icon = document.getElementById('iconYeuThich');
                var text = document.getElementById('textYeuThich');

                if (data.status === "DaLuu") {
                    // Nếu hệ thống báo đã lưu thành công -> Đổi nút sang màu đỏ đặc
                    btn.className = "btn w-100 rounded-pill fw-bold py-2 shadow-sm d-flex justify-content-center align-items-center gap-2 btn-danger";
                    icon.className = "bi bi-bookmark-heart-fill";
                    text.innerText = "Đã lưu vào Yêu thích";
                } else {
                    // Nếu hệ thống báo đã hủy lưu -> Đổi nút về viền rỗng ban đầu
                    btn.className = "btn w-100 rounded-pill fw-bold py-2 shadow-sm d-flex justify-content-center align-items-center gap-2 btn-outline-danger";
                    icon.className = "bi bi-bookmark-heart";
                    text.innerText = "Lưu vào Yêu thích";
                }
            } else {
                // Nếu chưa đăng nhập, hiển thị Modal bắt đăng nhập lên màn hình
                if (data.message === "Chưa đăng nhập") {
                    var myModal = new bootstrap.Modal(document.getElementById('reviewModal'));
                    myModal.show();
                } else {
                    alert(data.message);
                }
            }
        })
        .catch(error => console.error('Lỗi:', error));
    }
</script>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
    // Lấy tọa độ từ Model của C#, có xử lý chấm phẩy thập phân an toàn

http://googleusercontent.com/map_location_reference/1
    // Nếu quán chưa có tọa độ, mặc định chỉ về trung tâm [Nha Trang](http://googleusercontent.com/map_location_reference/0)
    var toaDoLat = @(Model.ViDo.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "12.2409935");
    var toaDoLng = @(Model.KinhDo.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "109.1963968");
    var tenQuan = "@Html.Raw(Model.TenDD)";
    var diaChi = "@Html.Raw(Model.DiaChiChiTiet)";

    var map; // Khai báo biến toàn cục để nút "Định vị lại" có thể gọi

    document.addEventListener("DOMContentLoaded", function () {
        // Khởi tạo bản đồ tại thẻ div 'chiTietMap'
        map = L.map('chiTietMap').setView([toaDoLat, toaDoLng], 16);

        // Nạp lớp bản đồ đường phố (TileLayer)
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '© OpenStreetMap'
        }).addTo(map);

        // Tạo biểu tượng điểm cắm tùy chỉnh (Marker) cho đẹp mắt
        var customIcon = L.divIcon({
            className: 'custom-pin',
            html: '<i class="bi bi-geo-alt-fill text-danger" style="font-size: 2rem; filter: drop-shadow(0px 3px 2px rgba(0,0,0,0.3));"></i>',
            iconSize: [30, 42],
            iconAnchor: [15, 42],
            popupAnchor: [0, -35]
        });

        // Gắn điểm cắm lên bản đồ
        var marker = L.marker([toaDoLat, toaDoLng], { icon: customIcon }).addTo(map);

        // Hiện khung popup chứa tên quán và địa chỉ khi click vào điểm cắm
        marker.bindPopup("<div class='text-center'><strong class='text-primary'>" + tenQuan + "</strong><br/><span class='small text-muted'>" + diaChi + "</span></div>");

        // Tự động mở popup khi tải trang
        setTimeout(function() { marker.openPopup(); }, 500);
    });
</script>