@model List<QuanLyAmThucNhaTrang.DAL.DANHGIA>
@{
    ViewBag.Title = "Lịch Sử Đánh Giá Cá Nhân";
}

<div class="container mt-5 mb-5" style="min-height: 60vh;">
    <div class="d-flex align-items-center gap-3 border-bottom pb-3 mb-5">
        <div class="bg-warning bg-opacity-10 text-warning p-3 rounded-circle d-inline-flex">
            <i class="bi bi-star-fill fs-3"></i>
        </div>
        <div>
            <h3 class="fw-bold m-0" style="font-family: 'Playfair Display', serif;">Lịch sử đánh giá</h3>
            <p class="text-muted small m-0">Xem lại những chia sẻ và đóng góp ý kiến của bạn về các địa điểm ẩm thực</p>
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="row justify-content-center">
            <div class="col-lg-9">
                @foreach (var item in Model)
                {
                    <div class="card border border-translucent shadow-sm rounded-4 p-4 mb-4 position-relative overflow-hidden"
                         style="transition: transform 0.2s; border-left: 5px solid #ffc107 !important;"
                         onmouseover="this.style.transform='translateX(5px)'"
                         onmouseout="this.style.transform='translateX(0)'">

                        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-2 mb-3">
                            <div>
                                <span class="badge bg-light text-primary border px-2 py-1 mb-2 small" style="font-size: 0.75rem;">
                                    <i class="bi bi-tag-fill me-1"></i> @item.DIADIEM.DANHMUC.TenDM
                                </span>
                                <h5 class="fw-bold m-0">
                                    <a href="@Url.Action("ChiTiet", "DiaDiem", new { id = item.MaDD })" class="text-dark text-decoration-none hover-link">
                                        @item.DIADIEM.TenDD
                                    </a>
                                </h5>
                                <small class="text-muted d-block mt-1"><i class="bi bi-geo-alt me-1"></i> @item.DIADIEM.DiaChiChiTiet</small>
                            </div>

                            <div class="text-muted small text-md-end">
                                <i class="bi bi-calendar3 me-1"></i> @item.NgayDanhGia.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>

                        <div class="bg-light rounded-3 px-3 py-2 d-inline-flex align-items-center gap-2 mb-3">
                            <span class="small fw-bold text-secondary">Bạn chấm:</span>
                            <div class="text-warning small">
                                @for (int i = 0; i < item.SoSao; i++)
                                {<i class="bi bi-star-fill"></i>}
                                @for (int i = item.SoSao; i < 5; i++)
                                {<i class="bi bi-star text-muted opacity-25"></i>}
                            </div>
                        </div>

                        <p class="text-secondary small m-0" style="line-height: 1.6; text-align: justify; font-style: italic;">
                            " @item.NoiDung "
                        </p>

                        <div class="d-flex justify-content-end mt-2">
                            <a href="@Url.Action("ChiTiet", "DiaDiem", new { id = item.MaDD })" class="btn btn-link btn-sm text-decoration-none fw-bold small p-0">
                                Ghé thăm lại quán <i class="bi bi-chevron-right small"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-chat-left-heart text-muted display-1"></i>
            <h5 class="text-muted mt-3 fw-bold">Chưa có bài đánh giá nào</h5>
            <p class="text-secondary small mb-4">Ý kiến của bạn sẽ giúp du khách có góc nhìn khách quan hơn khi chọn món ăn.</p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary rounded-pill px-4">Đi trải nghiệm và đánh giá</a>
        </div>
    }
</div>

<style>
    .hover-link:hover {
        color: #0d6efd !important;
        text-decoration: underline !important;
    }
</style>