@model QuanLyAmThucNhaTrang.DAL.TAIKHOAN
@{
    ViewBag.Title = "Quản Lý Trang Cá Nhân";
}

<div class="container mt-5 mb-5" style="min-height: 65vh;">
    <div class="row g-4">

        <div class="col-lg-4">
            <div class="card border border-translucent shadow-sm p-4 text-center rounded-4 position-sticky" style="top: 90px;">
                <div class="d-flex justify-content-center mb-3">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold fs-1"
                         style="width: 90px; height: 90px; border: 3px solid rgba(13, 110, 253, 0.2);">
                        @Model.HoTen.Substring(0, 1).ToUpper()
                    </div>
                </div>
                <h4 class="fw-bold mb-1">@Model.HoTen</h4>
                <p class="text-muted small mb-3">@@@Model.TenDangNhap</p>
                <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill small fw-bold mx-auto d-inline-block">
                    <i class="bi bi-person-badge-fill me-1"></i> Thành viên Khách hàng
                </span>

                <hr class="my-4 opacity-25">
                <div class="text-start text-muted small">
                    <p class="mb-2"><i class="bi bi-calendar-event me-2"></i>Ngày tham gia: @Model.NgayTao.ToString("dd/MM/yyyy")</p>
                    <p class="mb-0"><i class="bi bi-shield-check me-2"></i>Trạng thái: Đang hoạt động</p>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border border-translucent shadow-sm rounded-4 p-4">

                <ul class="nav nav-pills border-bottom pb-3 mb-4 gap-2" id="profileTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active rounded-pill px-4 fw-semibold small shadow-sm" id="info-tab" data-bs-toggle="tab" data-bs-target="#info-pane" type="button" role="tab" aria-controls="info-pane" aria-selected="true">
                            <i class="bi bi-person-lines-fill me-1"></i> Thông tin cá nhân
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link rounded-pill px-4 fw-semibold small" id="security-tab" data-bs-toggle="tab" data-bs-target="#security-pane" type="button" role="tab" aria-controls="security-pane" aria-selected="false">
                            <i class="bi bi-key-fill me-1"></i> Bảo mật & Mật khẩu
                        </button>
                    </li>
                </ul>

                <div class="tab-content pt-2" id="profileTabContent">

                    <div class="tab-pane fade show active" id="info-pane" role="tabpanel" aria-labelledby="info-tab" tabindex="0">
                        <form action="@Url.Action("CapNhatHoSo", "KhachHang")" method="POST">
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <label class="form-label small fw-bold text-secondary">Họ và tên của bạn</label>
                                    <input type="text" name="HoTen" class="form-control bg-light border-0 py-2.5" value="@Model.HoTen" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold text-secondary">Địa chỉ Email</label>
                                    <input type="email" name="Email" class="form-control bg-light border-0 py-2.5" value="@Model.Email" placeholder="Chưa cập nhật email..." />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold text-secondary">Số điện thoại liên hệ</label>
                                    <input type="tel" name="SDT" class="form-control bg-light border-0 py-2.5" value="@Model.SDT" placeholder="Chưa cập nhật số điện thoại..." />
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary rounded-pill fw-bold px-4 py-2 mt-4 shadow-sm">
                                <i class="bi bi-cloud-arrow-up-fill me-1"></i> Lưu thay đổi hồ sơ
                            </button>
                        </form>
                    </div>

                    <div class="tab-pane fade" id="security-pane" role="tabpanel" aria-labelledby="security-tab" tabindex="0">
                        <form action="@Url.Action("DoiMatKhau", "KhachHang")" method="POST" id="formDoiMatKhau">
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-secondary">Mật khẩu hiện tại</label>
                                <input type="password" name="MatKhauCu" class="form-control bg-light border-0 py-2.5" placeholder="********" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-secondary">Mật khẩu mới</label>
                                <input type="password" id="txtMatKhauMoi" name="MatKhauMoi" class="form-control bg-light border-0 py-2.5" placeholder="Tối thiểu 8 ký tự..." required />
                            </div>
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary">Xác nhận lại mật khẩu mới</label>
                                <input type="password" id="txtXacNhan" class="form-control bg-light border-0 py-2.5" placeholder="********" required />
                                <div id="msgLoiMatKhau" class="text-danger small mt-2 d-none">Mật khẩu xác nhận không trùng khớp!</div>
                            </div>
                            <button type="submit" class="btn btn-dark rounded-pill fw-bold px-4 py-2 shadow-sm">
                                <i class="bi bi-shield-lock-fill me-1"></i> Thay đổi mật khẩu bảo mật
                            </button>
                        </form>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>

<script>
    document.getElementById('formDoiMatKhau').addEventListener('submit', function (e) {
        var mkMoi = document.getElementById('txtMatKhauMoi').value;
        var xacNhan = document.getElementById('txtXacNhan').value;
        var errorDiv = document.getElementById('msgLoiMatKhau');

        if (mkMoi !== xacNhan) {
            e.preventDefault(); // Chặn việc submit form lên server
            errorDiv.classList.remove('d-none'); // Hiện thông báo lỗi
        } else {
            errorDiv.classList.add('d-none');
        }
    });
</script>