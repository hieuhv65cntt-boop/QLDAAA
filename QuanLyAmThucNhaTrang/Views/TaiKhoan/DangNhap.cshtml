
@{
    ViewBag.Title = "DangNhap";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-5 col-lg-4">
        <div class="card border-0 shadow-lg p-4" style="border-radius: 24px; background: rgba(255,255,255,0.9); backdrop-filter: blur(10px);">
            <div class="text-center mb-4">
                <div class="bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 70px; height: 70px;">
                    <i class="bi bi-shield-lock text-primary fs-1"></i>
                </div>
                <h2 class="fw-bold text-dark">Chào mừng trở lại</h2>
                <p class="text-muted small">Vui lòng đăng nhập để khám phá ẩm thực Nha Trang</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger border-0 small py-2 rounded-3">@ViewBag.Error</div>
            }

            <form action="@Url.Action("DangNhap", "TaiKhoan")" method="POST">
                <div class="mb-3">
                    <label class="form-label text-dark small fw-bold">Tên đăng nhập</label>
                    <div class="input-group">
                        <span class="input-group-text border-0"><i class="bi bi-person text-secondary"></i></span>
                        <input type="text" name="TenDangNhap" class="form-control border-0 py-2" placeholder="Nhập tên đăng nhập..." required />
                    </div>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between">
                        <label class="form-label text-dark small fw-bold">Mật khẩu</label>
                        <a href="#" class="text-decoration-none small">Quên mật khẩu?</a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text border-0"><i class="bi bi-key text-secondary"></i></span>
                        <input type="password" name="MatKhau" class="form-control border-0 py-2" placeholder="********" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-pill shadow-sm mb-3">
                    Đăng Nhập Ngay
                </button>

                <div class="text-center">
                    <p class="small text-muted">Chưa có tài khoản? <a href="@Url.Action("DangKy", "TaiKhoan")" class="fw-bold text-decoration-none">Đăng ký thành viên</a></p>
                </div>
            </form>
        </div>
    </div>
</div>
